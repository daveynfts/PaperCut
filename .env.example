# Server
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:5173
PRIVY_APP_ID=your-privy-app-id
PRIVY_APP_SECRET=
PRIVY_JWT_VERIFICATION_KEY=
ADMIN_EMAILS=admin@example.com

# Storage (Redis is required in production unless explicitly overridden)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
ALLOW_FILE_DB_IN_PRODUCTION=false

# Payments: disabled | mock | live
PAYMENT_MODE=mock
ALLOW_MOCK_PAYMENTS=false
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
PUBLISHER_WALLET_ID=
MOCK_PUBLISHER_WALLET=0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
SURFAI_ARTICLE_CONTENT=
SURFAI_PDF_URL=

# Frontend (place in vercel-demo-react/.env.local)
VITE_PRIVY_APP_ID=your-privy-app-id
VITE_API_URL=http://localhost:4000

# Contract deployment (use deploy-helper/.env when running Hardhat)
PRIVATE_KEY=
USDC_TOKEN_ADDRESS=
PLATFORM_FEE_BPS=500
