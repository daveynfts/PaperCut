{
  "manifest_version": 3,
  "name": "Lepton x402 Micropayment Auto-Signer",
  "version": "1.0.0",
  "description": "Chrome Extension for auto-signing USDC micropayments via EIP-3009 on the Arc Network.",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  },
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://127.0.0.1/*"
    ]
  }
}
